# Local dev (default): plain SQLite file, no auth token needed.
DATABASE_URL="file:./dev.db"

# Production (Vercel + Turso): uncomment and fill in, then set these as
# Vercel project environment variables (see README "Deployment" section).
# DATABASE_URL="libsql://<your-db>-<org>.turso.io"
# DATABASE_AUTH_TOKEN="<token from: turso db tokens create <your-db>>"

# Optional: enables a lightweight shared-secret gate (src/proxy.ts) for the
# public deployment. Leave unset to keep the app open (no auth), per spec.
# APP_SHARED_SECRET=""
